{
  "$schema": "https://raw.githubusercontent.com/Metta-AI/metta/main/packages/cogames/src/cogames/coworld/coworld_manifest_schema.json",
  "game": {
    "name": "stag_hunt",
    "version": "0.1.0",
    "description": "A cooperative BitWorld hunting game where players surround prey together: rabbits go down alone, but stags, moose, and elephants require coordinated multi-player encirclement.",
    "owner": "malcolm@softmax.com",
    "config_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tokens"
      ],
      "properties": {
        "tokens": {
          "description": "One connection token per player slot, indexed by slot.",
          "type": "array",
          "minItems": 0,
          "maxItems": 64,
          "items": {
            "type": "string",
            "minLength": 0
          },
          "default": []
        },
        "seed": {
          "description": "Random seed.",
          "type": "integer",
          "minimum": 0,
          "default": 5743127
        },
        "maxTicks": {
          "description": "Maximum simulation ticks per round (24 ticks/sec), where 0 means no tick limit.",
          "type": "integer",
          "minimum": 0,
          "default": 7200
        },
        "maxGames": {
          "description": "Maximum fresh games before shutdown, where 0 means no game limit.",
          "type": "integer",
          "minimum": 0,
          "default": 0
        }
      }
    },
    "results_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "names",
        "scores"
      ],
      "properties": {
        "names": {
          "description": "One player name or address per player slot.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "scores": {
          "description": "Cumulative hunting score per player slot across all rounds.",
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "stats": {
          "description": "Extended per-player statistics.",
          "type": "object",
          "properties": {
            "catches": {
              "description": "Per-player array of [rabbit, boar, stag, moose, elephant] capture counts.",
              "type": "array",
              "items": {
                "type": "array",
                "items": {
                  "type": "integer"
                }
              }
            },
            "co_captures": {
              "description": "NxN matrix of shared kills between player slots.",
              "type": "array",
              "items": {
                "type": "array",
                "items": {
                  "type": "integer"
                }
              }
            },
            "rounds": {
              "description": "Per-round score arrays.",
              "type": "array",
              "items": {
                "type": "array",
                "items": {
                  "type": "integer"
                }
              }
            }
          }
        }
      }
    },
    "protocols": {
      "player": "https://github.com/Metta-AI/bitworld/blob/master/docs/sprite_v1.md",
      "global": "https://github.com/Metta-AI/bitworld/blob/master/docs/sprite_v1.md"
    },
    "runnable": {
      "type": "game",
      "image": "ghcr.io/malcolmocean/bitworld-stag-hunt:latest",
      "run": ["/bin/stag_hunt", "--address:0.0.0.0", "--port:8080"]
    }
  },
  "player": [
    {
      "id": "coordinator",
      "name": "Coordinator",
      "description": "Strategic bot that picks high-value prey based on nearby ally count and coordinates encirclement using A* pathfinding.",
      "runnable": {
        "type": "player",
        "image": "ghcr.io/malcolmocean/bitworld-stag-hunt-coordinator:latest",
        "run": ["/bin/coordinator", "--address:host.docker.internal", "--port:8080"]
      }
    },
    {
      "id": "nearest-hunter",
      "name": "Nearest Hunter",
      "description": "Greedy bot that always chases the closest reachable prey using A* pathfinding.",
      "runnable": {
        "type": "player",
        "image": "ghcr.io/malcolmocean/bitworld-stag-hunt-nearest-hunter:latest",
        "run": ["/bin/nearest-hunter"]
      }
    },
    {
      "id": "rabbiteer",
      "name": "Rabbiteer",
      "description": "Specialist bot that prioritizes rabbits for guaranteed solo kills and consistent energy income.",
      "runnable": {
        "type": "player",
        "image": "ghcr.io/malcolmocean/bitworld-stag-hunt-rabbiteer:latest",
        "run": ["/bin/rabbiteer", "--address:host.docker.internal", "--port:8080"]
      }
    },
    {
      "id": "sidekick",
      "name": "Sidekick",
      "description": "Cooperative bot that follows nearby allies and assists with encirclement of larger prey.",
      "runnable": {
        "type": "player",
        "image": "ghcr.io/malcolmocean/bitworld-stag-hunt-sidekick:latest",
        "run": ["/bin/sidekick", "--address:host.docker.internal", "--port:8080"]
      }
    },
    {
      "id": "stag-hunter",
      "name": "Stag Hunter",
      "description": "Mid-tier specialist that targets stags and boars, balancing reward size against required coordination.",
      "runnable": {
        "type": "player",
        "image": "ghcr.io/malcolmocean/bitworld-stag-hunt-stag-hunter:latest",
        "run": ["/bin/stag-hunter"]
      }
    }
  ],
  "variants": [
    {
      "id": "smoke",
      "name": "Smoke",
      "game_config": {
        "seed": 5743127,
        "maxTicks": 7200,
        "maxGames": 1
      },
      "description": "Short deterministic Stag Hunt configuration used for manifest checks."
    }
  ],
  "certification": {
    "variant_id": "smoke",
    "players": [
      {
        "player_id": "coordinator",
        "initial_params": {
          "name": "coordinator_0"
        }
      },
      {
        "player_id": "nearest-hunter",
        "initial_params": {
          "name": "nearest_hunter_0"
        }
      }
    ]
  }
}
